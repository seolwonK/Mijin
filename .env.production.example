# ============================================================
# 프로덕션(CloudType) 환경변수 예시
# 실제 값은 CloudType 프로젝트의 "환경변수"에 입력하세요. 이 파일은 커밋용 예시입니다.
# ============================================================

# [필수] PostgreSQL 연결 문자열
#   CloudType Postgres 템플릿 사용 시 내부 호스트명으로 연결 (예: postgresql://user:pass@postgres:5432/mijin?schema=public)
#   외부 매니지드 DB(Neon/Supabase 등)면 sslmode=require 를 붙이세요.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mijin?schema=public"

# [필수] JWT 세션 서명 키 — 32자 이상. 생성: openssl rand -hex 32
AUTH_SECRET="change-me-with-openssl-rand-hex-32"

# [선택] 만족도 조사 링크 등 SMS에 실리는 절대 URL의 기준. 미설정 시 요청 origin 폴백.
APP_BASE_URL="https://your-domain.example"

# [선택] 외부 cron 백업이 /api/internal/auto-assign 을 호출할 때 사용하는 시크릿
#   설정하지 않아도 인프로세스 워커(30초 주기)가 자동배정을 수행합니다.
CRON_SECRET=""

# [선택] 카카오 로컬 API 키 (주소↔좌표 지오코딩). 없으면 주소/좌표 수동 입력으로 폴백.
KAKAO_REST_API_KEY=""

# [선택] SMS 발송 방식: console(로그만) | solapi(실발송). 미설정 시 발송 생략.
SMS_PROVIDER="console"

# [선택] SMS_PROVIDER=solapi 일 때만 필요
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
SOLAPI_SENDER=""

# [중요] 개인기술자 가입 휴대폰 본인인증. 실서비스는 반드시 portone 로 두세요.
#   mock 은 입력값을 그대로 통과시키므로 프로덕션에서 쓰면 안 됩니다.
#   PortOne(구 아임포트) 콘솔에서 본인인증 채널 등록 후 키를 발급받으세요.
IDENTITY_PROVIDER="portone"
NEXT_PUBLIC_IDENTITY_PROVIDER="portone"
PORTONE_API_SECRET=""
# PORTONE_STORE_ID=""                       # 멀티 상점 계정만 필요
NEXT_PUBLIC_PORTONE_STORE_ID=""
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=""

# [선택] 서버 STT (음성 녹음 → 텍스트 자동 변환): gemini | openai.
#   미설정 시 변환만 생략되고 녹음 재생은 그대로 동작.
STT_PROVIDER="gemini"
# gemini 사용 시 (키 발급: https://aistudio.google.com/apikey)
GEMINI_API_KEY=""
# GEMINI_STT_MODEL="gemini-2.5-flash"           # 기본값
# openai 사용 시
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"   # Groq 등 호환 서비스로 교체 가능
# OPENAI_STT_MODEL="whisper-1"

# [선택] 컨테이너 최초 기동 시 관리자/샘플 업체 계정 시드 (1이면 실행, upsert라 재실행 안전)
#   최초 배포 후에는 제거하거나 비워두세요.
RUN_DB_SEED="0"

# [선택] 업로드 저장 루트. 기본 /app/uploads. 스토리지를 다른 경로(예: /data)에
#   마운트했다면 그 경로로 지정. 기동 로그의 "업로드 디렉터리 쓰기 가능" 여부로 확인.
# UPLOADS_DIR="/app/uploads"
