generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROVIDER
  TECHNICIAN
}

// 개인기술자 근로형태: 일일 근로자 / 상시 근로자
enum EmploymentType {
  DAILY
  PERMANENT
}

// 임금 지급 형태 (월급/일급/시급)
enum WageType {
  MONTHLY
  DAILY
  HOURLY
}

// 임금 지급 방법
enum PayMethod {
  BANK_TRANSFER // 예금통장 입금
  DIRECT // 직접 지급
}

// 근로계약서 상태: 기술자 작성중 → 제출 → 관리자 확정
enum ContractStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
}

// 초긴급(1시간) / 긴급(2시간) / 일반
enum Urgency {
  CRITICAL
  URGENT
  NORMAL
}

enum RequestStatus {
  RECEIVED // 접수됨 = 배정 대기
  ASSIGNED // 배정됨 — 업체 응답 대기
  ACCEPTED // 업체 수락
  DISPATCHED // 출동중
  COMPLETED // 완료
  CANCELED // 관리자 취소
}

enum AssignmentStatus {
  REQUESTED
  ACCEPTED
  REJECTED
  CANCELED
}

enum AssignedBy {
  ADMIN
  AUTO
}

// 업체 가입 승인 상태 (셀프 가입은 PENDING으로 시작, 관리자 직접 등록은 APPROVED)
enum ProviderApproval {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String      @id @default(cuid())
  loginId      String      @unique
  passwordHash String
  name         String
  phone        String
  role         Role
  provider     Provider?
  technician   Technician?
  createdAt    DateTime    @default(now())
}

model Provider {
  id             String           @id @default(cuid())
  user           User             @relation(fields: [userId], references: [id])
  userId         String           @unique
  address        String
  lat            Float? // 셀프 가입 시 좌표를 모를 수 있음 — 좌표 없으면 거리계산·자동배정 제외
  lng            Float?
  isActive       Boolean          @default(true) // 비활성 업체는 배정 제외 (승인된 업체의 영업 on/off)
  memo           String?
  bizRegNo       String?          @unique // 사업자등록번호 (숫자 10자리)
  bizCertPath    String? // (레거시) 파일시스템 저장 경로 — 신규 가입은 bizCertFileId 사용
  bizCertFileId  String? // 사업자등록증 StoredFile id (DB 저장, 관리자만 열람)
  approvalStatus ProviderApproval @default(PENDING)
  rejectReason   String?
  appliedAt      DateTime         @default(now())
  approvedAt     DateTime?
  assignments    Assignment[]
}

// 개인기술자 — 업체(Provider)와 병렬로 배정 대상. 사업자 필드 대신 근로형태·근로계약서를 가진다.
model Technician {
  id             String              @id @default(cuid())
  user           User                @relation(fields: [userId], references: [id])
  userId         String              @unique
  address        String
  lat            Float? // 셀프 가입 시 좌표를 모를 수 있음 — 좌표 없으면 거리계산·자동배정 제외
  lng            Float?
  isActive       Boolean             @default(true) // 비활성 기술자는 배정 제외
  memo           String?
  employmentType EmploymentType // 일일(DAILY) / 상시(PERMANENT)
  approvalStatus ProviderApproval    @default(PENDING) // 업체와 동일한 승인 흐름 재사용
  rejectReason   String?
  appliedAt      DateTime            @default(now())
  approvedAt     DateTime?
  assignments    Assignment[]
  contract       EmploymentContract?

  @@index([approvalStatus])
}

// 표준 근로계약서 앞장. 기술자 1인당 1건(v1). 근무조건은 서버가 근로형태에 따라 강제 세팅,
// 임금 항목은 관리자가 입력·확정한다. 사업주(고용주) 정보는 AppSettings(미진전기)에서 가져온다.
model EmploymentContract {
  id             String         @id @default(cuid())
  technician     Technician     @relation(fields: [technicianId], references: [id])
  technicianId   String         @unique
  employmentType EmploymentType // 인쇄 무결성용 스냅샷

  // 근로개시일 / 계약기간 (null = 기간의 정함이 없음 — 상시 근로자)
  contractStartDate DateTime?
  contractEndDate   DateTime?

  // 근무장소 / 업무의 내용 (기술자 작성)
  workLocation   String
  jobDescription String

  // 소정근로시간·휴게시간 (근로형태에 따라 서버가 세팅, 기술자 읽기전용)
  workStartTime  String? // "09:00" — DAILY 는 null + hoursNote 로 대체
  workEndTime    String? // "18:00"
  breakStartTime String? // "12:00"
  breakEndTime   String? // "13:00"
  hoursNote      String? // "추후 협의 변동 가능" (상시) / "소정근로시간 1일 8시간" (일일)

  // 근무일 / 주휴일
  workDays      String // "월~금(주5일)" / "근로개시일 당일"
  weeklyHoliday String? // "일요일"

  // 임금 (관리자 입력)
  wageType       WageType?
  wageAmount     Int?
  bonusExists    Boolean    @default(false)
  bonusAmount    Int?
  otherPayExists Boolean    @default(false)
  otherPayDesc   String?
  otherPayAmount Int?
  payDate        String? // "매월 25일"
  payMethod      PayMethod?

  // 연차유급휴가 / 4대보험
  annualLeaveNote     String?  @default("근로기준법에 따라 부여")
  insuranceEmployment Boolean  @default(true) // 고용보험
  insuranceAccident   Boolean  @default(true) // 산재보험
  insurancePension    Boolean  @default(true) // 국민연금
  insuranceHealth     Boolean  @default(true) // 건강보험

  // 근로자(을) 기재란
  workerAddress       String?
  workerSignatureName String?
  // 근로자 손글씨 서명 (data URL PNG). 서명 시 계약이 확정된다.
  workerSignatureDataUrl String?
  signedAt               DateTime?

  status      ContractStatus @default(DRAFT)
  submittedAt DateTime?
  confirmedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ServiceRequest {
  id              String        @id @default(cuid())
  lookupCode      String        @unique // 6자리 숫자, 고객 조회용
  customerName    String
  customerPhone   String // 숫자만 정규화 저장
  description     String
  voicePath       String? // (레거시) 파일시스템 저장 경로 — 신규 접수는 voiceFileId 사용
  voiceFileId     String? // 음성 녹음 StoredFile id (DB 저장, 관리자만 열람)
  voiceMime       String? // audio/webm | audio/mp4 등 — 재생 시 Content-Type
  voiceTranscript String? // 서버 STT 변환 결과 (원본 보존, description과 별도)
  urgency         Urgency
  status          RequestStatus @default(RECEIVED)
  lat             Float?
  lng             Float? // 위치 거부 시 null 허용
  address         String? // 역지오코딩 or 수동 입력
  assignBaseAt    DateTime      @default(now()) // 자동배정 타이머 기준 시각
  needsAttention  Boolean       @default(false) // 자동배정 실패/거절 반환 플래그
  completedAt     DateTime?
  assignments     Assignment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, assignBaseAt]) // 자동배정 워커 스캔용
  @@index([customerPhone])
}

// 배정 이력 보존 — 재배정 추적. 현재 유효 배정 = REQUESTED/ACCEPTED 상태의 최신 1건
// 배정 대상은 업체(provider) 또는 개인기술자(technician) 중 정확히 하나.
// XOR 불변식은 앱(createAssignment) + DB CHECK 제약(마이그레이션 SQL)으로 강제한다.
model Assignment {
  id           String           @id @default(cuid())
  request      ServiceRequest   @relation(fields: [requestId], references: [id])
  requestId    String
  provider     Provider?        @relation(fields: [providerId], references: [id])
  providerId   String?
  technician   Technician?      @relation(fields: [technicianId], references: [id])
  technicianId String?
  status       AssignmentStatus @default(REQUESTED)
  assignedBy   AssignedBy
  distanceKm   Float?
  rejectReason String?
  respondedAt  DateTime?
  createdAt    DateTime         @default(now())

  @@index([providerId, status])
  @@index([technicianId, status])
  @@index([requestId])
}

// 싱글턴 (id=1)
model AppSettings {
  id                  Int      @id @default(1)
  autoAssignEnabled   Boolean  @default(false) // 수동 모드가 기본
  waitMinutesCritical Int      @default(10)
  waitMinutesUrgent   Int      @default(20)
  waitMinutesNormal   Int      @default(60)
  // 근로계약서 사업주(고용주) 정보 — 미진전기 고정, 모든 계약서에 자동 기입
  employerName        String   @default("미진전기")
  employerCeo         String? // 대표자
  employerAddress     String?
  employerPhone       String?
  employerBizRegNo    String? // 사업자등록번호
  // 회사 서명/직인 이미지 (data URL) — 모든 계약서 사업주 서명란에 자동 삽입
  employerSignatureDataUrl String?
  // 근로형태별 기본 임금 — 계약서 생성 시 자동 기입(관리자 수정 가능, 비우면 "추후 협의")
  defaultDailyWage    Int? // 일용 기본 일급
  defaultMonthlyWage  Int? // 상시 기본 월급
  defaultPayDate      String? // 기본 임금지급일 (예: "매월 25일")
  defaultPayMethod    PayMethod? // 기본 지급방법
  updatedAt           DateTime @updatedAt
}

model SmsLog {
  id        String   @id @default(cuid())
  to        String
  body      String
  provider  String // "solapi" | "console"
  status    String // "SENT" | "FAILED"
  error     String?
  requestId String?
  createdAt DateTime @default(now())
}

// 업로드 파일 본문 (음성 녹음·사업자등록증) — 볼륨 마운트 없이도 유지되도록
// 파일시스템 대신 DB(bytea)에 저장한다. 접근은 관리자 전용 라우트로만.
model StoredFile {
  id        String   @id @default(cuid())
  mime      String
  data      Bytes
  createdAt DateTime @default(now())
}

// 휴대폰 본인인증(PASS 등 통신사 본인확인) 완료 기록. 개인기술자 셀프 가입 게이트에 사용.
// provider=mock(개발) | portone(실서비스). 발급된 id 를 10분 내 가입 요청에 동봉해야 하며,
// 한 번 가입에 사용되면(consumedAt) 재사용 불가. name/phone 은 대행사가 검증한 실제 값.
model IdentityVerification {
  id          String    @id @default(cuid())
  provider    String // "mock" | "portone"
  providerRef String? // PortOne identityVerificationId 등 대행사측 식별자
  name        String // 인증된 실명
  phone       String // 숫자만 정규화 저장
  birthDate   String? // "YYYY-MM-DD"
  gender      String? // "MALE" | "FEMALE"
  ci          String? // 연계정보(개인 고유) — 중복가입 방지 등에 활용
  di          String? // 중복가입확인정보(사이트별)
  verifiedAt  DateTime  @default(now())
  expiresAt   DateTime // 이 시각까지 가입을 완료해야 유효
  consumedAt  DateTime? // 가입에 사용된 시각 (재사용 방지)
  createdAt   DateTime  @default(now())

  @@index([phone])
  @@index([ci])
}
